<?xml version="1.0" encoding="utf-8"?>
<!--
  Reusable transaction row.
  Bind data from MainActivity / TransactionAdapter using view IDs below.
-->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Coloured circle icon -->
    <FrameLayout
        android:id="@+id/frmTxIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true">

        <!-- Circle background (set tint programmatically) -->
<!--        <View-->
<!--            android:id="@+id/viewTxCircle"-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="match_parent"-->
<!--            android:background="@drawable/bg_circle_red" />-->

<!--        &lt;!&ndash; Direction arrow icon &ndash;&gt;-->
<!--        <ImageView-->
<!--            android:id="@+id/ivTxIcon"-->
<!--            android:layout_width="20dp"-->
<!--            android:layout_height="20dp"-->
<!--            android:layout_gravity="center"-->
<!--            android:src="@drawable/ic_arrow_up_right"-->
<!--            android:tint="#FFFFFF"-->
<!--            android:contentDescription="Transaction direction" />-->
    </FrameLayout>

    <!-- Name + subtitle -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/frmTxIcon"
        android:layout_centerVertical="true"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTxName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Priya Sharma"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTxSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Today, 6:42 PM"
            android:textColor="#888888"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Amount -->
    <TextView
        android:id="@+id/tvTxAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:text="-₹1,200"
        android:textColor="#FF6B6B"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Thin divider at bottom -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="56dp"
        android:background="#22FFFFFF" />

</RelativeLayout>
