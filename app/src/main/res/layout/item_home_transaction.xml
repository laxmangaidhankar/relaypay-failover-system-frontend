<?xml version="1.0" encoding="utf-8"?>
<!--
  Reusable home transaction row.
  Bind from HomeActivity / adapter:
    ivTxAvatar   → set src (avatar / icon)
    tvTxName     → recipient name
    tvTxDate     → "February 24, 2022"
    tvTxAmount   → "₹240.00"
-->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:paddingStart="0dp"
    android:paddingEnd="0dp"
    android:paddingTop="14dp"
    android:paddingBottom="14dp">

    <!-- Avatar / icon -->
    <ImageView
        android:id="@+id/ivTxAvatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:src="@drawable/il_running_man"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:contentDescription="@null" />

    <!-- Name + date -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/ivTxAvatar"
        android:layout_toStartOf="@id/tvTxAmount"
        android:layout_centerVertical="true"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTxName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Raj K"
            android:textColor="#111827"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTxDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="February 24, 2022"
            android:textColor="#9CA3AF"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Amount -->
    <TextView
        android:id="@+id/tvTxAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:text="₹240.00"
        android:textColor="#111827"
        android:textSize="15sp"
        android:textStyle="bold" />

    <!-- Bottom divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_alignParentBottom="true"
        android:background="#F3F4F6" />

</RelativeLayout>
