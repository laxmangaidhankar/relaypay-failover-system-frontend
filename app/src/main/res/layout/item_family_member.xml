<?xml version="1.0" encoding="utf-8"?>
<!--
  Reusable family member row.
  Bind from FamilyCircleActivity using view IDs:
    tvMemberInitials  — "LK", "MK", "RK", "SK"
    viewAvatarBg      — set background tint per member
    tvMemberName      — "Laxman (you)", "Mother", etc.
    tvMemberSubtitle  — "Admin · full access", "Member · ₹5,000 limit", etc.
    tvMemberBalance   — "₹4,100", "₹2,600", etc.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="#fff"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- Avatar circle with initials -->
        <FrameLayout
            android:id="@+id/frmAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true">

            <View
                android:id="@+id/viewAvatarBg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_avatar_circle" />

            <TextView
                android:id="@+id/tvMemberInitials"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="LK"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Name + subtitle -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/frmAvatar"
            android:layout_toStartOf="@id/tvMemberBalance"
            android:layout_centerVertical="true"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMemberName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Laxman (you)"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMemberSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Admin · full access"
                android:textColor="@color/relaypay_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Balance -->
        <TextView
            android:id="@+id/tvMemberBalance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="₹4,100"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>
