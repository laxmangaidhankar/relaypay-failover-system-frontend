<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/topBarHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="4dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Title row -->
        <!-- ── TOP BAR: logo + name ── -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"

            android:layout_height="150dp"
            android:elevation="4dp">

            <!-- Left Blue Circle -->
            <View
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:alpha="0.08"
                android:background="@drawable/bg_avatar_circle"
                android:translationX="-80dp"
                android:translationY="-80dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <!-- Right Green Circle -->
            <View
                android:layout_width="250dp"
                android:layout_height="250dp"
                android:alpha="0.08"
                android:background="@drawable/il_payment_people"
                android:translationX="60dp"
                android:translationY="-40dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginStart="20dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="History"
                android:textColor="#111827"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/ivLogo"
                app:layout_constraintTop_toTopOf="@id/ivLogo"
                app:layout_constraintBottom_toBottomOf="@id/ivLogo"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/white" />

        <!-- Filter chip row -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- All (active) -->
                <TextView
                    android:id="@+id/chipAll"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_blue_circle"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="All"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipSent"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="Sent"
                    android:textColor="@color/relaypay_text_secondary"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- Received -->
                <TextView
                    android:id="@+id/chipReceived"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="Received"
                    android:textColor="@color/relaypay_text_secondary"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true" />

<!--                &lt;!&ndash; Relayed &ndash;&gt;-->
                <TextView
                    android:id="@+id/chipRelayed"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="Relayed"
                    android:textColor="@color/relaypay_text_secondary"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true" />

<!--                &lt;!&ndash; Failed &ndash;&gt;-->
                <TextView
                    android:id="@+id/chipFailed"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="Failed"
                    android:textColor="@color/relaypay_text_secondary"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>
        </HorizontalScrollView>

    </LinearLayout>


    <!-- ══════════ SCROLL BODY ══════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="116dp"
        android:clipToPadding="false"

        android:paddingBottom="72dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="100dp"
            android:orientation="vertical">

            <!-- ══════ TODAY ══════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp"
                android:text="TODAY"
                android:textColor="@color/relaypay_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <include
                android:id="@+id/txPriya"
                layout="@layout/item_history_transaction" />

            <include
                android:id="@+id/txRohan"
                layout="@layout/item_history_transaction" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="72dp"
                android:background="@color/white" />

            <!-- 3. Family circle top-up — received/UPI — Settled -->
            <include
                android:id="@+id/txFamilyTopUp"
                layout="@layout/item_history_transaction" />

            <!-- ══════ YESTERDAY ══════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="6dp"
                android:text="YESTERDAY"
                android:textColor="@color/relaypay_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <!-- 4. Amazon Pay — failed/all rails failed — Failed -->
            <include
                android:id="@+id/txAmazon"
                layout="@layout/item_history_transaction" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="72dp"
                android:background="@color/white" />

            <!-- 5. Mother — sent/UPI — Settled -->
            <include
                android:id="@+id/txMother"
                layout="@layout/item_history_transaction" />

            <!-- bottom spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="16dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


</androidx.coordinatorlayout.widget.CoordinatorLayout>
