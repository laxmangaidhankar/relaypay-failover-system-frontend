<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <!-- ══════════ SCROLL BODY ══════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="72dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/headerLayout"
                android:layout_width="match_parent"

                android:layout_height="150dp"
                android:elevation="4dp">

                <!-- Left Blue Circle -->
                <View
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:alpha="0.08"
                    android:background="@drawable/bg_avatar_circle"
                    android:translationX="-80dp"
                    android:translationY="-80dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <!-- Right Green Circle -->
                <View
                    android:layout_width="250dp"
                    android:layout_height="250dp"
                    android:alpha="0.08"
                    android:background="@drawable/il_payment_people"
                    android:translationX="60dp"
                    android:translationY="-40dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />



                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="4dp"
                    android:layout_height="0dp"
                    android:layout_marginStart="20dp"

                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Profile"
                    android:textColor="#111827"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/ivLogo"
                    app:layout_constraintTop_toTopOf="@id/ivLogo"
                    app:layout_constraintBottom_toBottomOf="@id/ivLogo"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ── TOP BAR ── -->



            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Avatar circle -->
                <FrameLayout
                    android:layout_width="84dp"
                    android:layout_height="84dp">
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_avatar_circle" />

                    <TextView
                        android:id="@+id/tvProfileInitials"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:background="#19212F"
                        android:text="LK"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                </FrameLayout>

                <!-- Full name -->
                <TextView
                    android:id="@+id/tvProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Laxman Kadam"
                    android:textColor="@color/relaypay_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Phone -->
                <TextView
                    android:id="@+id/tvProfilePhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="+91 98xxx xxx21"
                    android:textColor="@color/relaypay_text_secondary"
                    android:textSize="13sp" />

            </LinearLayout>


            <!-- ── LINKED BANK + UPI CARDS ROW ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Linked bank card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="#1A1D26"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Primary bank"
                            android:textColor="@color/relaypay_text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvLinkedBank"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="HDFC ••4821"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- UPI ID card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="#1A1D26"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Virtual Acc No."
                            android:textColor="@color/relaypay_text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvUpiId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="1234567890"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>


            <!-- ── ACCOUNT SECTION ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="8dp"
                android:text="ACCOUNT"
                android:textColor="@color/relaypay_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <!-- Linked bank accounts -->
            <include
                android:id="@+id/menuLinkedBanks"
                layout="@layout/item_profile_menu" />

            <!-- Failover rail preferences -->
            <include
                android:id="@+id/menuFailoverRail"
                layout="@layout/item_profile_menu" />

            <!-- Manage family circle -->
            <include
                android:id="@+id/menuFamilyCircle"
                layout="@layout/item_profile_menu" />

            <!-- ── SECURITY SECTION ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="26dp"
                android:layout_marginBottom="8dp"
                android:text="SECURITY"
                android:textColor="@color/relaypay_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <!-- Change PIN -->
            <include
                android:id="@+id/menuChangePIN"
                layout="@layout/item_profile_menu" />

            <!-- Biometric login with switch -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="1dp"
                android:background="@color/white"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <!--                <ImageView-->
                <!--                    android:id="@+id/ivBiometricIcon"-->
                <!--                    android:layout_width="22dp"-->
                <!--                    android:layout_height="22dp"-->
                <!--                    android:layout_alignParentStart="true"-->
                <!--                    android:layout_centerVertical="true"-->
                <!--                    android:src="@drawable/ic_fingerprint"-->
                <!--                    android:tint="@color/relaypay_text_primary"-->
                <!--                    android:contentDescription="Biometric" />-->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="14dp"
                    android:text="Biometric login"
                    android:textColor="@color/relaypay_text_primary"
                    android:textSize="15sp"
                    android:textStyle="normal" />

                <!--                <androidx.appcompat.widget.SwitchCompat-->
                <!--                    android:id="@+id/switchBiometric"-->
                <!--                    android:layout_width="wrap_content"-->
                <!--                    android:layout_height="wrap_content"-->
                <!--                    android:layout_alignParentEnd="true"-->
                <!--                    android:layout_centerVertical="true"-->
                <!--                    android:checked="true"-->
                <!--                    app:thumbTint="@android:color/white"-->
                <!--                    app:trackTint="@color/switch_track_selector" />-->
            </RelativeLayout>

            <!-- Audit log -->
            <include
                android:id="@+id/menuAuditLog"
                layout="@layout/item_profile_menu" />


            <!-- ── LOG OUT BUTTON ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="24dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/relaypay_disabled_bg"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">

                                        <ImageView
                                            android:layout_width="18dp"
                                            android:layout_height="18dp"
                                            android:src="@drawable/ic_logout"
                                            android:contentDescription="Log out"
                                            app:tint="#ff0000" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="10dp"
                                            android:text="Log out"
                                            android:textColor="#ff0000"
                                            android:textSize="15sp"
                                            android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- bottom spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="20dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


</androidx.coordinatorlayout.widget.CoordinatorLayout>
