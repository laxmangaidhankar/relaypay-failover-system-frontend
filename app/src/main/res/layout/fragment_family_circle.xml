<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <!-- ══════════ SCROLL BODY ══════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="72dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── TOP BAR ── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">



                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Family circle"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!--                <ImageView-->
                <!--                    android:id="@+id/ivSettings"-->
                <!--                    android:layout_width="40dp"-->
                <!--                    android:layout_height="40dp"-->
                <!--                    android:layout_alignParentEnd="true"-->
                <!--                    android:layout_centerVertical="true"-->
                <!--                    android:padding="8dp"-->
                <!--                    android:src="@drawable/ic_settings"-->
                <!--                    android:tint="@color/relaypay_text_primary"-->
                <!--                    android:contentDescription="Settings"-->
                <!--                    android:clickable="true"-->
                <!--                    android:focusable="true" />-->
            </RelativeLayout>


            <!-- ── CIRCLE POOL BALANCE CARD ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="#19212F"

                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">



                    <!-- Description -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Invite your family members to send, receive, and manage payments together."
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <!-- Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddMember"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginTop="18dp"
                        android:text="Add Member"
                        app:backgroundTint="@color/brand_blue"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:drawableStart="@drawable/ic_addmoney"
                        android:drawablePadding="8dp"
                        app:cornerRadius="12dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <!-- ── MEMBERS HEADER ── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="Members"
                    android:textColor="#000"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvInvite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="+ Invite"
                    android:textColor="#1B1243"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </RelativeLayout>

            <!-- ── MEMBER ROWS ── -->

            <!-- 1. Laxman (you) — Admin -->
            <include
                android:id="@+id/memberLaxman"
                layout="@layout/item_family_member" />

            <!-- 2. Mother — Member -->
            <include
                android:id="@+id/memberMother"
                layout="@layout/item_family_member" />

            <!-- 3. Rohan (brother) — pending -->
            <include
                android:id="@+id/memberRohan"
                layout="@layout/item_family_member" />

            <!-- 4. Sister — Member -->
            <include
                android:id="@+id/memberSister"
                layout="@layout/item_family_member" />


            <!-- ── PENDING APPROVAL BANNER ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/bannerPendingApproval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#1A1D26"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <!-- Clock icon -->
                    <!--                    <ImageView-->
                    <!--                        android:id="@+id/ivPendingIcon"-->
                    <!--                        android:layout_width="22dp"-->
                    <!--                        android:layout_height="22dp"-->
                    <!--                        android:layout_alignParentStart="true"-->
                    <!--                        android:layout_centerVertical="true"-->
                    <!--                        android:src="@drawable/ic_schedule"-->
                    <!--                        android:tint="@color/relay_text"-->
                    <!--                        android:contentDescription="Pending" />-->

                    <!-- Text block -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rohan requested ₹500"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Awaiting your approval"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!--                    &lt;!&ndash; Chevron right &ndash;&gt;-->
                    <!--                    <ImageView-->
                    <!--                        android:id="@+id/ivChevron"-->
                    <!--                        android:layout_width="20dp"-->
                    <!--                        android:layout_height="20dp"-->
                    <!--                        android:layout_alignParentEnd="true"-->
                    <!--                        android:layout_centerVertical="true"-->
                    <!--                        android:src="@drawable/ic_chevron_right"-->
                    <!--                        android:tint="@color/relay_text"-->
                    <!--                        android:contentDescription="View details" />-->

                </RelativeLayout>
            </androidx.cardview.widget.CardView>


            <!-- ── SEND TO CIRCLE MEMBER BUTTON ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnSendToCircle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:background="#0D0F14"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <!--                    <ImageView-->
                    <!--                        android:layout_width="18dp"-->
                    <!--                        android:layout_height="18dp"-->
                    <!--                        android:src="@drawable/ic_send_diagonal"-->
                    <!--                        android:tint="@color/relaypay_text_primary"-->
                    <!--                        android:contentDescription="Send" />-->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Send to circle member"
                        android:textColor="@color/relaypay_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- bottom spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="16dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══════════ BOTTOM NAVIGATION ══════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:weightSum="5">

        <!-- Home (active) -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                android:contentDescription="Home"
                app:tint="#9CA3AF" />


        </LinearLayout>

        <!-- Bills / Transactions -->
        <LinearLayout
            android:id="@+id/navBills"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_history"
                android:contentDescription="Transactions"
                app:tint="#9CA3AF"
                />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navQr"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_qr_fab">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_scan"
                    android:contentDescription="Scan QR"
                    app:tint="#FFFFFF" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navFamily"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_group"
                android:contentDescription="Family"
                app:tint="#111827"
                />
            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginTop="3dp"
                android:background="@drawable/dot_active" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAccount"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_account"
                android:contentDescription="Account"
                app:tint="#9CA3AF" />
        </LinearLayout>

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
