<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <!-- ══════════ SCROLL BODY ══════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="72dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── TOP BAR ── -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/headerLayout"
                android:layout_width="match_parent"

                android:layout_height="150dp"
                android:elevation="4dp">

                <!-- Left Blue Circle -->
                <View
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:alpha="0.08"
                    android:background="@drawable/bg_avatar_circle"
                    android:translationX="-80dp"
                    android:translationY="-80dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <!-- Right Green Circle -->
                <View
                    android:layout_width="250dp"
                    android:layout_height="250dp"
                    android:alpha="0.08"
                    android:background="@drawable/il_payment_people"
                    android:translationX="60dp"
                    android:translationY="-40dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginStart="20dp"

                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Family Circle"
                    android:textColor="#111827"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/ivLogo"
                    app:layout_constraintTop_toTopOf="@id/ivLogo"
                    app:layout_constraintBottom_toBottomOf="@id/ivLogo"/>

            </androidx.constraintlayout.widget.ConstraintLayout>


            <!-- ── CIRCLE POOL BALANCE CARD ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="#19212F"

                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">



                    <!-- Description -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Invite your family members to send, receive, and manage payments together."
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <!-- Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddMember"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginTop="18dp"
                        android:text="Add Member"
                        app:backgroundTint="@color/brand_blue"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:drawablePadding="8dp"
                        app:cornerRadius="12dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <!-- ── MEMBERS HEADER ── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="Members"
                    android:textColor="#000"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvInvite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="+ Invite"
                    android:textColor="#1B1243"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </RelativeLayout>

            <!-- ── MEMBER ROWS ── -->

            <!-- 1. Laxman (you) — Admin -->
            <include
                android:id="@+id/memberLaxman"
                layout="@layout/item_family_member" />

            <!-- 2. Mother — Member -->
            <include
                android:id="@+id/memberMother"
                layout="@layout/item_family_member" />

            <!-- 3. Rohan (brother) — pending -->
            <include
                android:id="@+id/memberRohan"
                layout="@layout/item_family_member" />

            <!-- 4. Sister — Member -->
            <include
                android:id="@+id/memberSister"
                layout="@layout/item_family_member" />


            <!-- ── PENDING APPROVAL BANNER ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/bannerPendingApproval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#1A1D26"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

            </androidx.cardview.widget.CardView>


            <!-- ── SEND TO CIRCLE MEMBER BUTTON ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnSendToCircle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:background="#0D0F14"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Send to circle member"
                        android:textColor="@color/relaypay_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- bottom spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="16dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


</androidx.coordinatorlayout.widget.CoordinatorLayout>
